# Set explicit trusted origins only (no wildcard in production)
ALLOWED_ORIGINS=https://copas.io,https://www.copas.io,http://localhost:3000
PORT=8000

# Cookie file path for authenticated downloads (Instagram, TikTok private)
# Export your browser cookies to Netscape format, then set this path
# yt-dlp --cookies-from-browser chrome --cookies /path/to/cookies.txt
YTDLP_COOKIE_FILE=/path/to/cookies.txt

# Facebook fallback adapter configuration
# Self-hosted provider for Facebook extraction when yt-dlp fails
FACEBOOK_FALLBACK_ENABLED=false
FACEBOOK_FALLBACK_BASE_URL=
FACEBOOK_FALLBACK_TIMEOUT_SECONDS=30
PORT=8000

# Cookie file path for authenticated downloads (Instagram, TikTok private)
# Export your browser cookies to Netscape format, then set this path
# yt-dlp --cookies-from-browser chrome --cookies /path/to/cookies.txt
YTDLP_COOKIE_FILE=/path/to/cookies.txt
